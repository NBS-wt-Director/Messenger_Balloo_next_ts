{
  "name": "@balloo/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Balloo Messenger Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "cd renderer && npm run dev",
    "dev:electron": "wait-on http://localhost:3000 && electron . --dev",
    "build": "npm run build:renderer && electron-builder",
    "build:renderer": "cd renderer && npm run build",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "eslint electron/ renderer/src/"
  },
  "build": {
    "appId": "ru.balloo.messenger",
    "productName": "Balloo Messenger",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "renderer/build/**/*"
    ],
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "assets/icon.icns",
      "category": "public.app-category.social-networking"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "icon": "assets/icon.png",
      "category": "Network;InstantMessaging;"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.0",
    "axios": "^1.7.0",
    "jose": "^5.9.0",
    "@balloo/shared": "*"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "concurrently": "^9.0.0",
    "wait-on": "^8.0.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.0.0"
  }
}
