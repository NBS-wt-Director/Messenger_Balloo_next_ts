# ===========================================
# BALLOO MESSENGER - ENVIRONMENT VARIABLES
# Скопируйте этот файл в .env.local и заполните значениями
# ===========================================

# ===========================================
# JWT & SECURITY
# ===========================================
# Секретный ключ для подписи JWT токенов (минимум 32 символа)
# Сгенерировать: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# Ключ шифрования для E2EE (минимум 32 символа)
ENCRYPTION_KEY=your-encryption-key-min-32-chars

# Пароль для RxDB базы данных
RXDB_PASSWORD=your-database-password

# ===========================================
# YANDEX OAUTH
# ===========================================
# Client ID из Яндекс OAuth консоли
# https://oauth.yandex.ru/client/new
NEXT_PUBLIC_YANDEX_CLIENT_ID=your-yandex-client-id

# Client Secret из Яндекс OAuth консоли
YANDEX_CLIENT_SECRET=your-yandex-client-secret

# ===========================================
# PUSH NOTIFICATIONS (VAPID)
# ===========================================
# Сгенерировать с помощью: web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Email для VAPID (указывайте реальный email)
VAPID_EMAIL=your-email@example.com

# ===========================================
# SERVER CONFIGURATION
# ===========================================
# URL приложения (без слэша в конце)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Порт сервера
PORT=3000

# Режим работы (development/production)
NODE_ENV=development

# ===========================================
# YANDEX DISK (OPTIONAL)
# ===========================================
# Папка для загрузки файлов на Яндекс.Диске
YANDEX_DISK_FOLDER=balloo-uploads

# ===========================================
# ADMIN CONFIGURATION
# ===========================================
# Email супер-администратора (для первоначальной настройки)
ADMIN_EMAIL=admin@balloo.ru

# ===========================================
# DATABASE
# ===========================================
# Имя базы данных RxDB
RXDB_DATABASE_NAME=balloo

# ===========================================
# FEATURE FLAGS
# ===========================================
# Включить режим отладки
DEBUG=false

# Включить логирование в production
LOGGING_ENABLED=false

# ===========================================
# RATE LIMITING
# ===========================================
# Максимум запросов в минуту
RATE_LIMIT_MAX=100

# Окно времени для rate limiting (в секундах)
RATE_LIMIT_WINDOW=60
