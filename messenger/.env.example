# ==========================================
# Balloo Messenger - Переменные окружения
# ==========================================
# СКОПИРУЙТЕ ЭТОТ ФАЙЛ В .env.local
# И ЗАПОЛНИТЕ ВСЕ ЗНАЧЕНИЯ
# ==========================================

# ===== ОБЯЗАТЕЛЬНО (заменить на свои) =====

# Адрес сервера (без слэша в конце)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# SQLite Database (встроена в проект, один файл)
# БД будет создана автоматически в prisma/dev.db
DATABASE_URL="file:./prisma/dev.db"

# Yandex OAuth - получить на https://oauth.yandex.ru/
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Yandex Disk API
YANDEX_DISK_API_URL=https://cloud-api.yandex.net/v1/disk
YANDEX_DISK_TOKEN=

# ===== БЕЗОПАСНОСТЬ (сгенерировать новые) =====

# JWT Secret (минимум 32 символа)
# Сгенерировать: openssl rand -base64 32
JWT_SECRET=change-this-to-32-characters-minimum
NEXTAUTH_SECRET=

# Encryption Key (минимум 32 символа)
ENCRYPTION_KEY=change-this-encryption-key-minimum-32-chars

# ===== PUSH-УВЕДОМЛЕНИЯ =====

# VAPID ключи: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ваш-домен.ru

# ===== EMAIL (опционально) =====

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ===== РЕЖИМ РАБОТЫ =====

NODE_ENV=development
PORT=3000

# ===== ЛОГИРОВАНИЕ =====

LOG_LEVEL=debug

# ===== АДМИНИСТРИРОВАНИЕ =====

ADMIN_EMAIL=admin@ваш-домен.ru

# ===== SQLITE НАСТРОЙКИ =====

# Автоматическое создание БД при старте
PRISMA_AUTO_MIGRATE=true

# ==========================================
# ВАЖНО: Не коммитьте .env.local в git!
# Файл БД (dev.db) тоже не коммитьте!
# ==========================================
