# ==========================================
# Balloo Messenger - Переменные окружения
# ==========================================
# СКОПИРУЙТЕ ЭТОТ ФАЙЛ В .env.local
# И ЗАПОЛНИТЕ ВСЕ ЗНАЧЕНИЯ
# ==========================================

# ===== ОБЯЗАТЕЛЬНО (заменить на свои) =====

# Адрес сервера (без слэша в конце)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Yandex OAuth - получить на https://oauth.yandex.ru/
# Создайте приложение, укажите redirect URI:
# http://localhost:3000/api/auth/yandex/callback (для dev)
# https://ваш-домен.ru/api/auth/yandex/callback (для prod)
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Yandex Disk API
# Получить токен: https://oauth.yandex.ru/authorize?response_type=token&client_id=ВАШ_CLIENT_ID
YANDEX_DISK_API_URL=https://cloud-api.yandex.net/v1/disk
YANDEX_DISK_TOKEN=

# ===== БЕЗОПАСНОСТЬ (сгенерировать новые) =====

# Секретный ключ для сессий (обязательно смените!)
# Сгенерировать: openssl rand -base64 32
NEXTAUTH_SECRET=

# ===== PUSH-УВЕДОМЛЕНИЯ (заполнить из config.json) =====

# VAPID ключи генерируются командой:
# npx web-push generate-vapid-keys
# Публичный ключ также нужно вставить в config.json
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ваш-домен.ru

# ===== EMAIL (опционально, для уведомлений) =====

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ===== РЕЖИМ РАБОТЫ =====

# production | development
NODE_ENV=development

# Порт сервера
PORT=3000

# ===== ЛОГИРОВАНИЕ =====

# debug | info | warn | error
LOG_LEVEL=debug

# ===== АДМИНИСТРИРОВАНИЕ =====

# Email первого администратора (для уведомлений)
ADMIN_EMAIL=

# ==========================================
# ВАЖНО: Не коммитьте .env.local в git!
# ==========================================
