# ==========================================
# Balloo Messenger - Переменные окружения
# ==========================================
# СКОПИРУЙТЕ ЭТОТ ФАЙЛ В .env.local
# И ЗАПОЛНИТЕ ВСЕ ЗНАЧЕНИЯ
# ==========================================

# ===== ОБЯЗАТЕЛЬНО (заменить на свои) =====

# Адрес сервера (без слэша в конце)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=https://alpha.balloo.su
NEXT_PUBLIC_APP_NAME=Balloo Messenger

# SQLite Database (встроена в проект, один файл)
# БД будет создана автоматически в data/app.db
DATABASE_URL=file:./data/app.db

# ===== БЕЗОПАСНОСТЬ (сгенерировать новые) =====

# JWT Secret (минимум 32 символа)
# Сгенерировать: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-here-min-32-chars
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# Encryption Key (минимум 32 символа)
ENCRYPTION_KEY=your-random-32-character-encryption-key

# Пароль для установщика (изменить в production!)
INSTALLER_PASSWORD=change-this-to-secure-password

# ===== PUSH-УВЕДОМЛЕНИЯ =====

# VAPID ключи: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:your-email@example.com

# ===== YANDEX OAUTH =====

YANDEX_CLIENT_ID=your-yandex-client-id
YANDEX_CLIENT_SECRET=your-yandex-client-secret
YANDEX_REDIRECT_URI=https://your-domain.com/api/auth/yandex-disk/callback

# ===== EMAIL (опционально) =====

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# ===== РЕЖИМ РАБОТЫ =====

NODE_ENV=development
PORT=3000
DEBUG=false
LOGGING_ENABLED=true

# ===== ЛОГИРОВАНИЕ =====

LOG_LEVEL=debug

# ===== АДМИНИСТРИРОВАНИЕ =====

SUPER_ADMIN_EMAIL=admin@balloo.ru
DEFAULT_ADMIN_PASSWORD=change-this-in-production!

# ===== ТЕСТОВЫЕ ПОЛЬЗОВАТЕЛИ (опционально) =====

TEST_USER_1_EMAIL=test1@balloo.ru
TEST_USER_1_PASSWORD=Test1234!
TEST_USER_2_EMAIL=test2@balloo.ru
TEST_USER_2_PASSWORD=Test1234!

# ==========================================
# ВАЖНО: Не коммитьте .env.local в git!
# Файл БД (app.db) тоже не коммитьте!
# ==========================================
