{
  "name": "@balloo/android-service",
  "version": "1.0.0",
  "private": true,
  "description": "Balloo Android Service - SMS, Admin Panel, Push Notifications",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "build:android": "cd android && ./gradlew assembleRelease",
    "lint": "eslint src/",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "compression": "^1.7.4",
    "winston": "^3.15.0",
    "socket.io": "^4.8.0",
    "axios": "^1.7.0",
    "jose": "^5.9.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.0",
    "nodemailer": "^6.9.0",
    "twilio": "^5.3.0",
    "firebase-admin": "^13.0.0",
    "@balloo/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.0",
    "@types/compression": "^1.7.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/nodemailer": "^6.4.0",
    "typescript": "^5.7.0",
    "ts-node": "^10.9.0",
    "nodemon": "^3.1.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.14"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
