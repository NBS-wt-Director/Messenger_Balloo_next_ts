{
  "name": "balloo-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "messenger",
    "mobile",
    "desktop",
    "android-service",
    "shared"
  ],
  "scripts": {
    "dev:web": "cd messenger && npm run dev",
    "dev:mobile": "cd mobile && npm run start",
    "dev:desktop": "cd desktop && npm run dev",
    "dev:android-service": "cd android-service && npm run dev",
    "build:web": "cd messenger && npm run build",
    "build:mobile": "cd mobile && npm run build",
    "build:desktop": "cd desktop && npm run build",
    "build:android-service": "cd android-service && npm run build",
    "build:all": "npm run build:web && npm run build:mobile && npm run build:desktop && npm run build:android-service",
    "lint": "npm run lint:web && npm run lint:mobile && npm run lint:desktop",
    "lint:web": "cd messenger && npm run lint",
    "lint:mobile": "cd mobile && npm run lint",
    "lint:desktop": "cd desktop && npm run lint",
    "test": "npm run test:web && npm run test:mobile",
    "test:web": "cd messenger && npm test",
    "test:mobile": "cd mobile && npm test"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
